{
  "name": "md-to-pdf-tool",
  "version": "1.0.0",
  "description": "Markdown to PDF 转换工具",
  "repository": {
    "type": "git",
    "url": "md-to-pdf-tool"
  },
  "license": "Apache License Version 2.0",
  "author": "Skrepy",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
